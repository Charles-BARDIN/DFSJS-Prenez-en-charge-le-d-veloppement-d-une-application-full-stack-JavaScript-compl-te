# Chaîne de connexion à la base de données
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://user:password@localhost:5434/mdd_db?schema=public"

# Configuration Auth.js (NextAuth v5)
# Générer une valeur sûre en production : npx auth secret
AUTH_SECRET="your-secret-key-here-change-in-production"
AUTH_URL="http://localhost:3000"

# Tests end-to-end : créer un fichier .env.test distinct, pointant vers une base
# de test ISOLÉE (port 5435) pour ne jamais toucher la base de développement.
# DATABASE_URL="postgresql://user:password@localhost:5435/mdd_test?schema=public"
# AUTH_SECRET="test-secret-not-for-production"
# AUTH_URL="http://localhost:3100"
